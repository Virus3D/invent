{% extends 'base.html.twig' %}

{% trans_default_domain 'inventory' %}
{% set title = item.name %}

{% block body %}
    {% include '_breadcrumb.html.twig' with {
        'item': item,
        'type': 'inventory'
    } %}

    <div class="row">
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-info-circle"></i> {{ 'inventory_item.show.main_info'|trans }}
                    </h5>
                    <span class="{{ item.categoryBadgeClass }}">
                        <i class="bi {{ item.category.icon }}"></i> {{ item.category|trans }}
                    </span>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">{{ 'inventory_item.show.name_label'|trans }}</dt>
                        <dd class="col-sm-9">{{ item.name }}</dd>

                        <dt class="col-sm-3">{{ 'inventory_item.info.inventory_number_label'|trans }}</dt>
                        <dd class="col-sm-9">
                            {% if item.isOnBalance() %}
                                <code>{{ item.inventoryNumber }}</code>
                            {% else %}
                                <span class="badge bg-secondary">
                                    <i class="bi bi-x-circle"></i> {{ 'inventory_item.balance_type.off_balance'|trans }}
                                </span>
                            {% endif %}
                        </dd>

                        {% if item.serialNumber %}
                        <dt class="col-sm-3">{{ 'inventory_item.show.serial_number_label'|trans }}</dt>
                        <dd class="col-sm-9">{{ item.serialNumber }}</dd>
                        {% endif %}

                        <dt class="col-sm-3">{{ 'inventory_item.info.current_location_label'|trans }}</dt>
                        <dd class="col-sm-9">
                            {% if item.location %}
                                <a href="{{ path('app_location_show', {'id': item.location.id}) }}">
                                    {{ item.location }}
                                </a>
                            {% else %}
                                <span class="text-muted">{{ 'inventory_item.not_location'|trans }}</span>
                            {% endif %}
                        </dd>

                        <dt class="col-sm-3">{{ 'inventory_item.show.date_added_label'|trans }}</dt>
                        <dd class="col-sm-9">{{ item.createdAt|date('d.m.Y H:i') }}</dd>

                        <dt class="col-sm-3">{{ 'inventory_item.show.last_update_label'|trans }}</dt>
                        <dd class="col-sm-9">{{ item.updatedAt|date('d.m.Y H:i') }}</dd>
                    </dl>

                    {% if item.description %}
                        <hr>
                        <h6>{{ 'inventory_item.show.description_label'|trans }}</h6>
                        <p class="card-text">{{ item.description|nl2br }}</p>
                    {% endif %}

                    {% if item.specifications|length > 0 %}
                        <hr>
                        <h6><i class="bi bi-cpu"></i> {{ 'inventory_item.show.specifications'|trans }}</h6>
                        <div class="row">
                            {% for key, value in item.specifications %}
                                {% if value %}
                                    <div class="col-md-6 mb-2">
                                        <small class="text-muted">{{ ('inventory_item.spec_labels.' ~ key)|default(key|replace({'_': ' '})|title)|trans }}:</small>
                                        <br><strong>{{ value }}</strong>
                                    </div>
                                {% endif %}
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
                <div class="card-footer d-flex justify-content-between align-items-center">
                    <div class="btn-group">
                        <a href="{{ path('app_inventory_edit', {'id': item.id}) }}"
                           class="btn btn-primary">
                            <i class="bi bi-pencil"></i> {{ 'common.actions.edit'|trans(domain: 'messages') }}
                        </a>
                        <a href="{{ path('app_inventory_move', {'id': item.id}) }}"
                           class="btn btn-warning">
                            <i class="bi bi-arrow-left-right"></i> {{ 'common.actions.move'|trans(domain: 'messages') }}
                        </a>
                    </div>
                    <button type="button"
                            class="btn btn-danger"
                            data-bs-toggle="modal"
                            data-bs-target="#deleteModal">
                        <i class="bi bi-trash"></i> {{ 'common.actions.delete'|trans(domain: 'messages') }}
                    </button>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            {{ include('inventory/_move_history.html.twig', {movementLogs: item.movementLogs}) }}
        </div>

        <div class="col-md-8">
            {{ include('cartridge/_cartridge_block.html.twig') }}
        </div>
    </div>
{% include 'modal/_delete.html.twig' with {
    'message': '<p>' ~ 'inventory_item.delete.message'|trans({'%name%': item.name}) ~ '</p><p class="text-muted small">' ~  'inventory_item.delete.inventory_number'|trans({'%number%': item.inventoryNumber}) ~ '</p>',
    'path': path('app_inventory_delete', {'id': item.id}),
    'token': csrf_token('delete' ~ item.id)
} %}
{% endblock %}