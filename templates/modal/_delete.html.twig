<!-- Модальное окно удаления -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle"></i> {{ 'common.modals.delete.title'|trans }}
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <strong>{{ 'common.messages.warning'|trans }}</strong> {{ 'common.modals.delete.warning'|trans }}
                </div>
                {{ message|raw }}
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'common.actions.cancel'|trans }}</button>
                <form method="post" action="{{ path }}" class="d-inline">
                    <input type="hidden" name="_token" value="{{ token }}">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> {{ 'common.actions.delete'|trans }}
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>