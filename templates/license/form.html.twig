{% extends 'base.html.twig' %}

{% form_theme form 'form/fields.html.twig' %}
{% trans_default_domain 'license' %}
{% set title = page_title|trans %}

{% block body %}
<div class="container-fluid py-4">
    {% include '_breadcrumb.html.twig' with {
        'item': license,
        'type': 'license',
        'action': (license.id) ? 'edit' : 'create'
    } %}

    <div class="row">
        <div class="col-12 col-md-8 offset-md-2 col-lg-6 offset-lg-3">
            <div class="card shadow">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">
                        <i class="bi bi-shield-lock"></i> {{ page_title|trans }}
                    </h4>
                    {% if license.id %}
                        <span class="badge bg-light text-dark">
                            ID: {{ license.id }}
                        </span>
                    {% endif %}
                </div>

                <div class="card-body">
                    {{ form_start(form, {
                        'attr': {
                            'id': 'licenseForm',
                            'class': 'needs-validation was-validated',
                            'novalidate': 'novalidate',
                            'data-controller': 'edit-form',
                            'data-edit-form-target': 'form',
                            'data-edit-form-url-value': license.id ? path('api_license_update', {'id': license.id}) : path('api_license_create'),
                        }
                    }) }}

                    {{ form_row(form.name) }}
                    {{ form_row(form.licenseKey) }}

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            {{ form_row(form.startDate) }}
                        </div>
                        <div class="col-md-6 mb-3">
                            {{ form_row(form.endDate) }}
                        </div>
                    </div>

                    {{ form_row(form.valid) }}

                    {{ form_row(form.location) }}

                    <hr class="my-4">

                    <div class="d-flex justify-content-between">
                        <div>
                            {% if license.id %}
                            <a href="{{ path('app_license_show', {'id': license.id}) }}"
                               class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle"></i> {{ 'common.actions.cancel'|trans(domain: 'messages') }}
                            </a>
                            <!-- Кнопка удаления с подтверждением -->
                            <button type="button"
                                    class="btn btn-outline-danger ms-2"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deleteModal">
                                <i class="bi bi-trash"></i> {{ 'common.actions.delete'|trans(domain: 'messages') }}
                            </button>
                            {% else %}
                            <a href="{{ path('app_license_index') }}" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> {{ 'common.actions.cancel'|trans(domain: 'messages') }}
                            </a>
                            {% endif %}
                        </div>
                        <div>
                            <button type="submit"
                                    class="btn btn-primary"
                                    data-edit-form-target="submitButton"
                                    data-action="edit-form#submitForm">
                                <i class="bi bi-check-circle"></i> {{ 'common.actions.submit'|trans(domain: 'messages') }}
                            </button>
                        </div>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>

{% if license.id %}
{% include 'modal/_delete.html.twig' with {
    'message': 'license.delete.confirm'|trans,
    'path': path('app_license_delete', {'id': license.id}),
    'token': csrf_token('delete' ~ license.id)
} %}
{% endif %}

{% include 'modal/_success.html.twig' %}

{% endblock %}

