{% extends 'base.html.twig' %}

{% trans_default_domain 'license' %}
{% set title = license.name %}

{% block body %}
    {% include '_breadcrumb.html.twig' with {
        'item': license,
        'type': 'license'
    } %}

    <div class="row">
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-info-circle"></i> {{ 'license.show.main_info'|trans }}
                    </h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">{{ 'license.show.name_label'|trans }}</dt>
                        <dd class="col-sm-9">{{ license.name }}</dd>

                        <dt class="col-sm-3">{{ 'license.show.key_label'|trans }}</dt>
                        <dd class="col-sm-9">{{ license.licenseKey ?? '—' }}</dd>

                        <dt class="col-sm-3">{{ 'license.show.start_date_label'|trans }}</dt>
                        <dd class="col-sm-9">{{ license.startDate|date('d.m.Y') }}</dd>

                        <dt class="col-sm-3">{{ 'license.show.end_date_label'|trans }}</dt>
                        <dd class="col-sm-9">
                            {% if license.endDate %}
                                {{ license.endDate|date('d.m.Y') }}
                            {% else %}
                                <span class="badge bg-info">{{ 'license.perpetual'|trans }}</span>
                            {% endif %}
                        </dd>

                        <dt class="col-sm-3">{{ 'license.show.location_label'|trans }}</dt>
                        <dd class="col-sm-9">
                            {% if license.location %}
                                <a href="{{ path('app_location_show', {'id': license.location.id}) }}">
                                    {{ license.location }}
                                </a>
                            {% else %}
                                <span class="text-muted">{{ 'license.not_location'|trans }}</span>
                            {% endif %}
                        </dd>

                        <dt class="col-sm-3">{{ 'license.show.valid_label'|trans }}</dt>
                        <dd class="col-sm-9">
                            {% if license.valid %}
                                <span class="badge bg-success">{{ 'license.valid.yes'|trans }}</span>
                            {% else %}
                                <span class="badge bg-danger">{{ 'license.valid.no'|trans }}</span>
                            {% endif %}
                        </dd>

                        <dt class="col-sm-3">{{ 'license.show.date_added_label'|trans }}</dt>
                        <dd class="col-sm-9">{{ license.createdAt|date('d.m.Y H:i') }}</dd>

                        <dt class="col-sm-3">{{ 'license.show.last_update_label'|trans }}</dt>
                        <dd class="col-sm-9">{{ license.updatedAt|date('d.m.Y H:i') }}</dd>
                    </dl>
                </div>
                <div class="card-footer">
                    <div class="btn-group">
                        <a href="{{ path('app_license_edit', {'id': license.id}) }}"
                           class="btn btn-primary">
                            <i class="bi bi-pencil"></i> {{ 'common.actions.edit'|trans(domain: 'messages') }}
                        </a>
                        <button type="button"
                                class="btn btn-danger"
                                data-bs-toggle="modal"
                                data-bs-target="#deleteModal">
                            <i class="bi bi-trash"></i> {{ 'common.actions.delete'|trans(domain: 'messages') }}
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% include 'modal/_delete.html.twig' with {
    'message': 'license.delete.confirm'|trans,
    'path': path('app_license_delete', {'id': license.id}),
    'token': csrf_token('delete' ~ license.id)
} %}
{% endblock %}

