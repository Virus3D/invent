{% extends 'base.html.twig' %}

{% set title = 'page_title.dashboard'|trans %}

{% block body %}
<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="h2">
                <i class="bi bi-speedometer2"></i> {{ title }}
            </h1>
            <p class="text-muted">{{ 'dashboard.description'|trans }}</p>
        </div>
    </div>

    <!-- Статистика -->
    <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                {{ 'inventory_item.all'|trans(domain: 'inventory') }}
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                {{ stats.total_items }}
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-box-seam fa-2x text-primary"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                {{ 'location.all'|trans(domain: 'location') }}
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                {{ stats.total_locations }}
                            </div>
                            <div class="mt-2 mb-0 text-muted text-xs">
                                <i class="bi bi-building"></i> {{ 'location.description'|trans(domain: 'location') }}
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-geo-alt fa-2x text-success"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-warning shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                                {{ 'move.all'|trans(domain: 'move') }}
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                {{ stats.total_movements }}
                            </div>
                            <div class="mt-2 mb-0 text-muted text-xs">
                                {% if stats.last_movement %}
                                    <i class="bi bi-calendar-event"></i>
                                    {{ 'common.last'|trans }}: {{ stats.last_movement|date('d.m.Y') }}
                                {% endif %}
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-arrow-left-right fa-2x text-warning"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-info shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                                {{ 'placement.without_binding'|trans }}
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                {{ itemsWithoutLocation|length }}
                            </div>
                            <div class="mt-2 mb-0 text-muted text-xs">
                                <i class="bi bi-exclamation-triangle"></i> {{ 'placement.require'|trans }}
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-question-circle fa-2x text-info"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Основной контент -->
    <div class="row">
        <!-- Недавние перемещения -->
        <div class="col-xl-8 col-lg-7 mb-4">
            {{ include('dashboard/_move_block.html.twig') }}
        </div>

        <!-- Быстрые действия и объекты без привязки -->
        <div class="col-xl-4 col-lg-5">
            <!-- Быстрые действия -->
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-success">
                        <i class="bi bi-lightning-charge"></i> {{ 'common.actions.quick'|trans }}
                    </h6>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        {{ include('dashboard/_quick_actions.html.twig') }}
                    </div>
                </div>
            </div>

            <!-- Объекты без привязки -->
            <div class="card shadow">
                <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                    <h6 class="m-0 font-weight-bold text-warning">
                        <i class="bi bi-exclamation-triangle"></i> {{ 'placement.without_binding'|trans }}
                    </h6>
                    <span class="badge bg-warning">{{ itemsWithoutLocation|length }}</span>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        {% for item in itemsWithoutLocation|slice(0, 5) %}
                            <div class="list-group-item">
                                <div class="d-flex w-100 justify-content-between align-items-center">
                                    <div>
                                        <h6 class="mb-1">{{ item.name }}</h6>
                                        <small class="text-muted">{{ item.inventoryNumber }}</small>
                                    </div>
                                    <div class="btn-group">
                                        <a href="{{ path('app_inventory_edit', {'id': item.id}) }}"
                                           class="btn btn-sm btn-outline-primary" title="{{ 'common.actions.edit'|trans }}">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a href="{{ path('app_inventory_move', {'id': item.id}) }}"
                                           class="btn btn-sm btn-outline-warning" title="{{ 'common.actions.post'|trans }}">
                                            <i class="bi bi-geo-alt"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        {% else %}
                            <div class="list-group-item text-center text-muted py-4">
                                <i class="bi bi-check-circle display-6"></i>
                                <p class="mt-2 mb-0">{{ 'placement.all_placed'|trans }}</p>
                            </div>
                        {% endfor %}
                    </div>
                    {% if itemsWithoutLocation|length > 5 %}
                        <div class="card-footer text-center">
                            <a href="{{ path('app_inventory_index') }}?filter=unassigned" class="btn btn-sm btn-link">
                                {{ 'placement.all_placed'|trans({count: itemsWithoutLocation|length}) }}
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <!-- Распределение по категориям -->
    <div class="row mt-4">
        <div class="col-12">
            {{ include('dashboard/_categorization.html.twig') }}
        </div>
    </div>
</div>

{# {% include 'modal/_mass_move.html.twig' %} #}
{% endblock %}
