{% extends 'base.html.twig' %}

{% form_theme form 'form/fields.html.twig' %}
{% trans_default_domain 'material' %}
{% set title = page_title|trans %}

{% block body %}
<div class="container-fluid py-4">
    {% include '_breadcrumb.html.twig' with {
        'item': material,
        'type': 'material',
        'action': (material.id) ? 'edit' : 'create'
    } %}

    <div class="row">
        <div class="col-12 col-md-8 offset-md-2 col-lg-6 offset-lg-3">
            <div class="card shadow">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">
                        <i class="bi bi-pencil"></i> {{ page_title|trans }}
                    </h4>
                    {% if material.id %}
                    <span class="badge bg-light text-dark">
                        ID: {{ material.id }}
                    </span>
                    {% endif %}
                </div>

                <div class="card-body">
                    {{ form_start(form, {
                        'attr': {
                            'id': 'materialForm',
                            'class': 'needs-validation was-validated',
                            'novalidate': 'novalidate',
                            'data-controller': 'edit-form',
                            'data-edit-form-target': 'form',
                            'data-edit-form-url-value': material.id ? path('api_material_update', {'id': material.id}) : path('api_material_create'),
                        }
                    }) }}

                    <div data-edit-form-target="errorContainer"
                        class="alert alert-danger d-none"
                        role="alert"></div>

                    {{ form_widget(form) }}

                    <hr class="my-4">

                    <div class="d-flex justify-content-between">
                        <div>
                            {% if material.id %}
                            <a href="{{ path('app_material_show', {'id': material.id}) }}"
                               class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle"></i> {{ 'common.actions.cancel'|trans(domain: 'messages') }}
                            </a>
                            <!-- Кнопка удаления с подтверждением -->
                            <button type="button"
                                    class="btn btn-outline-danger ms-2"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deleteModal">
                                <i class="bi bi-trash"></i> {{ 'common.actions.delete'|trans(domain: 'messages') }}
                            </button>
                            {% else %}
                            <a href="{{ path('app_material_index') }}" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> {{ 'common.actions.cancel'|trans(domain: 'messages') }}
                            </a>
                            {% endif %}
                        </div>
                        <div>
                            <button type="submit"
                                    class="btn btn-primary"
                                    data-edit-form-target="submitButton"
                                    data-action="edit-form#submitForm">
                                <i class="bi bi-check-circle"></i> {{ 'common.actions.submit'|trans(domain: 'messages') }}
                            </button>
                        </div>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>

{% if material.id %}
{% include 'modal/_delete.html.twig' with {
    'message': 'material.delete.confirm'|trans,
    'path': path('app_material_delete', {'id': material.id}),
    'token': csrf_token('delete' ~ material.id)
} %}
{% endif %}

{% include 'modal/_success.html.twig' %}

{% endblock %}
